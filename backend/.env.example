# ============================================================
#  .env — Environment Variables
#  RENAME this file to .env and fill in your real values
#  NEVER commit .env to GitHub — it has your passwords!
# ============================================================

# ── Gmail Setup ────────────────────────────────────────────
# Your Gmail address (the one that SENDS the email)
GMAIL_USER=yourgmail@gmail.com

# Gmail App Password (NOT your normal Gmail password)
# How to get it:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification → Turn ON
#   3. Security → App Passwords
#   4. Select "Mail" + "Windows Computer" → Generate
#   5. Copy the 16-character password here (no spaces)
GMAIL_PASSWORD=abcd efgh ijkl mnop

# ── Where to receive emails ────────────────────────────────
# Can be same as GMAIL_USER or a different address
RECEIVER_EMAIL=srinivassathwikmaddali@gmail.com

# ── Admin Panel Password ───────────────────────────────────
# Change this to something unique — used to view messages
ADMIN_KEY=sathwik_admin_2025

# ── Flask Settings ─────────────────────────────────────────
PORT=5000

# ── Frontend URL (for CORS in production) ─────────────────
FRONTEND_URL=https://yourdomain.com
